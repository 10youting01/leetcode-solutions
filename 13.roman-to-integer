class Solution:
    def romanToInt(self, s: str) -> int:
        ans = 0
        roman = {'I':1, 'V':5, 'X':10, 'L':50, 'C':100, 'D':500, 'M':1000}
        for i in range(len(s)):
            curr_val = roman[s[i]]
            next_val = roman[s[i+1]] if (i+1) < len(s) else 0
            if  curr_val < next_val:
                ans -= curr_val
            else:
                ans += curr_val
        return ans
                
                
